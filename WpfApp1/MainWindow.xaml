<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfApp1.Models"
        Title="ARSADECK"
        Icon="Assets/arsadeck.ico"
        Height="750" Width="980"
        MinHeight="750" MinWidth="980"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>

        <local:LedModeToBoolConverter x:Key="LedModeToBoolConverter"/>

        <Style x:Key="TileBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="0"
                                      ShadowDepth="0"
                                      Opacity="0"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1.05" Duration="0:0:0.08"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1.05" Duration="0:0:0.08"/>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="#88FFFFFF" Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="12" Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.7" Duration="0:0:0.10"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.10"/>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="#555555" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="0" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>

                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="BorderBrush" Value="#00FFFF"/>
                    <Setter Property="BorderThickness" Value="2.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00FFFF"
                                              BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.9"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IosToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="#777777"/>
            <Setter Property="BorderBrush" Value="#777777"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="SwitchTrack"
                                    CornerRadius="12"
                                    Background="#777777"/>
                            <Border x:Name="SwitchThumb"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="White"
                                    Margin="2,2,22,2">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      ShadowDepth="0"
                                                      Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#32CD32"
                                                            Duration="0:0:0.12"/>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="22,2,2,2"
                                                                Duration="0:0:0.10"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#777777"
                                                            Duration="0:0:0.12"/>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="2,2,22,2"
                                                                Duration="0:0:0.10"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack"
                                        Property="Background"
                                        Value="#444444"/>
                                <Setter TargetName="SwitchThumb"
                                        Property="Background"
                                        Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2,0,2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#4A4A4A"
                                                            Duration="0:0:0.10"/>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#FFFFFF"
                                                            Duration="0:0:0.10"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.04"
                                                             Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.04"
                                                             Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#3A3A3A"
                                                            Duration="0:0:0.12"/>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#555555"
                                                            Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.0"
                                                             Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.0"
                                                             Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2F2F2F"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="4,0,24,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <Path x:Name="Arrow"
                                          HorizontalAlignment="Right"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 4 4 L 8 0"
                                          Stroke="White"
                                          StrokeThickness="1.3"/>
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border CornerRadius="4"
                                        Background="#2E2E2E"
                                        BorderBrush="#555555"
                                        BorderThickness="1">
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleButton" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush x:Name="NeonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop x:Name="NeonStop1" Color="#120032" Offset="0.0"/>
            <GradientStop x:Name="NeonStop2" Color="#0030AA" Offset="0.3"/>
            <GradientStop x:Name="NeonStop3" Color="#00B5FF" Offset="0.7"/>
            <GradientStop x:Name="NeonStop4" Color="#6A00FF" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">

                    <ColorAnimation Storyboard.TargetName="NeonStop2"
                                    Storyboard.TargetProperty="Color"
                                    From="#0030AA"
                                    To="#008CFF"
                                    AutoReverse="True"
                                    Duration="0:0:4"/>
                    <ColorAnimation Storyboard.TargetName="NeonStop3"
                                    Storyboard.TargetProperty="Color"
                                    From="#00B5FF"
                                    To="#00FFE0"
                                    AutoReverse="True"
                                    Duration="0:0:4"/>
                    <ColorAnimation Storyboard.TargetName="NeonStop4"
                                    Storyboard.TargetProperty="Color"
                                    From="#6A00FF"
                                    To="#D200FF"
                                    AutoReverse="True"
                                    Duration="0:0:4"/>

                    <DoubleAnimation Storyboard.TargetName="NeonStop1"
                                     Storyboard.TargetProperty="Offset"
                                     From="0.0" To="0.2"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>
                    <DoubleAnimation Storyboard.TargetName="NeonStop2"
                                     Storyboard.TargetProperty="Offset"
                                     From="0.3" To="0.5"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>
                    <DoubleAnimation Storyboard.TargetName="NeonStop3"
                                     Storyboard.TargetProperty="Offset"
                                     From="0.7" To="0.9"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>
                    <DoubleAnimation Storyboard.TargetName="NeonStop4"
                                     Storyboard.TargetProperty="Offset"
                                     From="1.0" To="1.2"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>

                    <PointAnimationUsingKeyFrames
                        Storyboard.TargetName="NeonBrush"
                        Storyboard.TargetProperty="StartPoint"
                        Duration="0:0:16" RepeatBehavior="Forever">
                        <LinearPointKeyFrame Value="0,0" KeyTime="0:0:0"/>
                        <LinearPointKeyFrame Value="1,0" KeyTime="0:0:4"/>
                        <LinearPointKeyFrame Value="1,1" KeyTime="0:0:8"/>
                        <LinearPointKeyFrame Value="0,1" KeyTime="0:0:12"/>
                        <LinearPointKeyFrame Value="0,0" KeyTime="0:0:16"/>
                    </PointAnimationUsingKeyFrames>

                    <PointAnimationUsingKeyFrames
                        Storyboard.TargetName="NeonBrush"
                        Storyboard.TargetProperty="EndPoint"
                        Duration="0:0:16" RepeatBehavior="Forever">
                        <LinearPointKeyFrame Value="1,1" KeyTime="0:0:0"/>
                        <LinearPointKeyFrame Value="0,1" KeyTime="0:0:4"/>
                        <LinearPointKeyFrame Value="0,0" KeyTime="0:0:8"/>
                        <LinearPointKeyFrame Value="1,0" KeyTime="0:0:12"/>
                        <LinearPointKeyFrame Value="1,1" KeyTime="0:0:16"/>
                    </PointAnimationUsingKeyFrames>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="18"
            Background="#CC05040A"
            Margin="6">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="COM-порт: "
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="White"/>

                    <ComboBox x:Name="PortComboBox"
                              Width="120"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              SelectionChanged="PortComboBox_SelectionChanged"
                              Style="{StaticResource TopComboBoxStyle}"/>

                    <Button Content="Обновить"
                            Click="RefreshPortsButton_Click"
                            Margin="0,0,8,0"
                            Style="{StaticResource TopButtonStyle}"/>

                    <Button Content="Сохранить"
                            Click="SaveConfigButton_Click"
                            Margin="0,0,8,0"
                            Style="{StaticResource TopButtonStyle}"/>

                    <Button Content="Отправить"
                            Click="SendConfigButton_Click"
                            Margin="0,0,8,0"
                            Style="{StaticResource TopButtonStyle}"/>

                    <Button Content="Очистить"
                            Click="ClearDataButton_Click"
                            Margin="0,0,8,0"
                            Style="{StaticResource TopButtonStyle}"/>

                    <TextBlock x:Name="PortStatusText"
                               VerticalAlignment="Center"
                               Foreground="White"
                               Margin="4,0,0,0"
                               Text="Порт не выбран"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,12,0">
                    <TextBlock Text="Конфиг: "
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="White"/>

                    <ComboBox x:Name="ConfigComboBox"
                              Width="170"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              SelectionChanged="ConfigComboBox_SelectionChanged"
                              Style="{StaticResource TopComboBoxStyle}"/>

                    <Button Content="Сохранить как"
                            Click="SaveConfigAsButton_Click"
                            Margin="0,0,8,0"
                            Style="{StaticResource TopButtonStyle}"/>

                    <Button Content="Удалить"
                            Click="DeleteConfigButton_Click"
                            Style="{StaticResource TopButtonStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="–"
                            Width="30"
                            Height="24"
                            Margin="8,0,4,0"
                            Click="MinimizeButton_Click"
                            Style="{StaticResource TopButtonStyle}"/>

                    <Button Content="X"
                            Width="30"
                            Height="24"
                            Click="CloseButton_Click"
                            Style="{StaticResource TopButtonStyle}"/>
                </StackPanel>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding KeysBoxes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="3" Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="8"
                                Style="{StaticResource TileBorderStyle}">

                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Выбрать EXE (режим запуска)"
                                              Click="PickExeMenuItem_Click"/>
                                    <MenuItem Header="Выбрать картинку (режим кастом)"
                                              Click="PickImageMenuItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Переименовать (кастом)"
                                              Click="RenameCustomMenuItem_Click"/>
                                    <MenuItem Header="Сбросить кастом"
                                              Click="ResetCustomMenuItem_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>

                            <Grid Margin="4">
                                <Border CornerRadius="10"
                                        Background="#1A1A1A">
                                    <Grid Margin="3"
                                          ClipToBounds="True">
                                        <Border CornerRadius="8"
                                                Background="#2A2A2A"/>

                                        <Grid Margin="6" Opacity="0.95">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid.Resources>
                                                <Style x:Key="AppIconStyle" TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static local:KeyBoxType.App}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>

                                                <Style x:Key="CustomImageStyle" TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static local:KeyBoxType.Custom}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Resources>

                                            <Image x:Name="AppIcon"
                                                   Grid.Row="0"
                                                   Source="{Binding Icon}"
                                                   Width="40" Height="40"
                                                   Style="{StaticResource AppIconStyle}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                            <Image x:Name="CustomImageControl"
                                                   Grid.Row="0"
                                                   Source="{Binding CustomImage}"
                                                   Width="70" Height="70"
                                                   Style="{StaticResource CustomImageStyle}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                            <Border Grid.Row="1"
                                                    Margin="4,4,4,2"
                                                    CornerRadius="6"
                                                    Padding="6,2">
                                                <Border.Background>
                                                    <LinearGradientBrush x:Name="AppTitleBgBrush" StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop x:Name="AppTitleBgStop1" Color="#2200FFFF" Offset="0.0"/>
                                                        <GradientStop x:Name="AppTitleBgStop2" Color="#4400FFC8" Offset="0.5"/>
                                                        <GradientStop x:Name="AppTitleBgStop3" Color="#2200FFFF" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>

                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetName="AppTitleBgStop1"
                                                                                 Storyboard.TargetProperty="Offset"
                                                                                 From="0.0" To="1.0"
                                                                                 Duration="0:0:4"
                                                                                 RepeatBehavior="Forever"/>

                                                                <DoubleAnimation Storyboard.TargetName="AppTitleBgStop2"
                                                                                 Storyboard.TargetProperty="Offset"
                                                                                 From="0.5" To="1.5"
                                                                                 Duration="0:0:4"
                                                                                 RepeatBehavior="Forever"/>

                                                                <DoubleAnimation Storyboard.TargetName="AppTitleBgStop3"
                                                                                 Storyboard.TargetProperty="Offset"
                                                                                 From="1.0" To="2.0"
                                                                                 Duration="0:0:4"
                                                                                 RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>

                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="#FFFFFF"
                                                           HorizontalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           FontSize="12"/>
                                            </Border>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Title}"
                                                       Foreground="#FFFFFF"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,2"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>

                                            <ToggleButton Grid.Row="3"
                                                          Style="{StaticResource IosToggleStyle}"
                                                          IsChecked="{Binding Mode,
                                                                              Converter={StaticResource LedModeToBoolConverter},
                                                                              Mode=TwoWay}"
                                                          HorizontalAlignment="Center"
                                                          Margin="0,2,0,0"/>

                                            <StackPanel Grid.Row="4"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,2,0,0">
                                                <TextBlock Text="Toggle"
                                                           Foreground="#CCCCCC"
                                                           Margin="0,0,4,0"
                                                           FontSize="10"/>
                                                <TextBlock Text="Hold"
                                                           Foreground="#CCCCCC"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border CornerRadius="8"
                                                Background="#20FFFFFF"
                                                BorderBrush="#55FFFFFF"
                                                BorderThickness="1"
                                                IsHitTestVisible="False">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8"
                                                                  ShadowDepth="1.5"
                                                                  Direction="315"
                                                                  Opacity="0.4"
                                                                  Color="#66000000"/>
                                            </Border.Effect>

                                            <Grid>
                                                <Border CornerRadius="8"
                                                        VerticalAlignment="Top"
                                                        Height="26">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#60FFFFFF" Offset="0.0"/>
                                                            <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                                                            <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="2"
                       Text="ПКМ по квадрату - выбрать программу. Переключатель - режим TOGGLE/HOLD. F13-F24 - запуск."
                       HorizontalAlignment="Center"
