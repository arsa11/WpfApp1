<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfApp1.Models"
        Title="ARSADECK"
        Height="1000" Width="624"
        MinHeight="1000" MinWidth="624"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>

        <local:LedModeToBoolConverter x:Key="LedModeToBoolConverter"/>

        <Style x:Key="TileBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1.4"/>
            <Setter Property="BorderBrush" Value="#31435C"/>
            <Setter Property="Background" Value="#111722"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="12"
                                      ShadowDepth="3"
                                      Opacity="0.36"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1.03"
                                                 Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1.03"
                                                 Duration="0:0:0.10"/>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="#00E5FF"
                                                Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="18"
                                                 Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.72"
                                                 Duration="0:0:0.10"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>

                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1.0"
                                                 Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1.0"
                                                 Duration="0:0:0.12"/>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="#31435C"
                                                Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="12"
                                                 Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.36"
                                                 Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>

                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="BorderBrush" Value="#00F0FF"/>
                    <Setter Property="BorderThickness" Value="2.2"/>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#162330" Offset="0.0"/>
                                <GradientStop Color="#11263A" Offset="0.5"/>
                                <GradientStop Color="#0E1C2C" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00F0FF"
                                              BlurRadius="30"
                                              ShadowDepth="0"
                                              Opacity="1"/>
                        </Setter.Value>
                    </Setter>

                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="1.0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="0.95"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.02"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.0"/>
                                </DoubleAnimationUsingKeyFrames>

                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="1.0"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="0.95"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.02"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.0"/>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IosToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="#6A6A6A"/>
            <Setter Property="BorderBrush" Value="#6A6A6A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="SwitchTrack"
                                    CornerRadius="12"
                                    Background="#6A6A6A"/>
                            <Border x:Name="SwitchThumb"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="White"
                                    Margin="2,2,22,2">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5"
                                                      ShadowDepth="0"
                                                      Opacity="0.45"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#00D26A"
                                                            Duration="0:0:0.12"/>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="22,2,2,2"
                                                                Duration="0:0:0.10"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#6A6A6A"
                                                            Duration="0:0:0.12"/>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="2,2,22,2"
                                                                Duration="0:0:0.10"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack"
                                        Property="Background"
                                        Value="#444444"/>
                                <Setter TargetName="SwitchThumb"
                                        Property="Background"
                                        Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#25272E"/>
            <Setter Property="BorderBrush" Value="#49566B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="4,1,4,1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#323743"
                                                            Duration="0:0:0.10"/>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#00E5FF"
                                                            Duration="0:0:0.10"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.03"
                                                             Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.03"
                                                             Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#25272E"
                                                            Duration="0:0:0.12"/>
                                            <ColorAnimation Storyboard.TargetName="ButtonBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#49566B"
                                                            Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.0"
                                                             Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.0"
                                                             Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#1E2128"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#20242C"/>
            <Setter Property="BorderBrush" Value="#49566B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="6,0,24,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <Path x:Name="Arrow"
                                          HorizontalAlignment="Right"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 4 4 L 8 0"
                                          Stroke="White"
                                          StrokeThickness="1.3"/>
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border CornerRadius="6"
                                        Background="#20242C"
                                        BorderBrush="#49566B"
                                        BorderThickness="1">
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleButton" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#1B1F27"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#00D7FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="4">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="14"
                                                  ShadowDepth="3"
                                                  Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#F4F8FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#004E66" Offset="0"/>
                                            <GradientStop Color="#008FA8" Offset="0.5"/>
                                            <GradientStop Color="#004E66" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#7A8596"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSeparatorStyle" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Margin="8,6"
                                Background="#394556"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">

                    <ColorAnimation Storyboard.TargetName="NeonStop2"
                                    Storyboard.TargetProperty="Color"
                                    From="#002E78"
                                    To="#008CFF"
                                    AutoReverse="True"
                                    Duration="0:0:4"/>
                    <ColorAnimation Storyboard.TargetName="NeonStop3"
                                    Storyboard.TargetProperty="Color"
                                    From="#00A7FF"
                                    To="#00FFE0"
                                    AutoReverse="True"
                                    Duration="0:0:4"/>
                    <ColorAnimation Storyboard.TargetName="NeonStop4"
                                    Storyboard.TargetProperty="Color"
                                    From="#4F1DFF"
                                    To="#B100FF"
                                    AutoReverse="True"
                                    Duration="0:0:4"/>

                    <DoubleAnimation Storyboard.TargetName="NeonStop1"
                                     Storyboard.TargetProperty="Offset"
                                     From="0.0" To="0.2"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>
                    <DoubleAnimation Storyboard.TargetName="NeonStop2"
                                     Storyboard.TargetProperty="Offset"
                                     From="0.3" To="0.5"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>
                    <DoubleAnimation Storyboard.TargetName="NeonStop3"
                                     Storyboard.TargetProperty="Offset"
                                     From="0.7" To="0.9"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>
                    <DoubleAnimation Storyboard.TargetName="NeonStop4"
                                     Storyboard.TargetProperty="Offset"
                                     From="1.0" To="1.2"
                                     AutoReverse="True"
                                     Duration="0:0:10"/>

                    <PointAnimationUsingKeyFrames
                        Storyboard.TargetName="NeonBrush"
                        Storyboard.TargetProperty="StartPoint"
                        Duration="0:0:16" RepeatBehavior="Forever">
                        <LinearPointKeyFrame Value="0,0" KeyTime="0:0:0"/>
                        <LinearPointKeyFrame Value="1,0" KeyTime="0:0:4"/>
                        <LinearPointKeyFrame Value="1,1" KeyTime="0:0:8"/>
                        <LinearPointKeyFrame Value="0,1" KeyTime="0:0:12"/>
                        <LinearPointKeyFrame Value="0,0" KeyTime="0:0:16"/>
                    </PointAnimationUsingKeyFrames>

                    <PointAnimationUsingKeyFrames
                        Storyboard.TargetName="NeonBrush"
                        Storyboard.TargetProperty="EndPoint"
                        Duration="0:0:16" RepeatBehavior="Forever">
                        <LinearPointKeyFrame Value="1,1" KeyTime="0:0:0"/>
                        <LinearPointKeyFrame Value="0,1" KeyTime="0:0:4"/>
                        <LinearPointKeyFrame Value="0,0" KeyTime="0:0:8"/>
                        <LinearPointKeyFrame Value="1,0" KeyTime="0:0:12"/>
                        <LinearPointKeyFrame Value="1,1" KeyTime="0:0:16"/>
                    </PointAnimationUsingKeyFrames>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border CornerRadius="20"
                Margin="6"
                ClipToBounds="True"
                BorderBrush="#00D7FF"
                BorderThickness="1.2">
            <Border.Effect>
                <DropShadowEffect Color="#00BFFF"
                                  BlurRadius="16"
                                  ShadowDepth="0"
                                  Opacity="0.28"/>
            </Border.Effect>

            <Border.Background>
                <LinearGradientBrush x:Name="NeonBrush" StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="NeonStop1" Color="#14002D" Offset="0.0"/>
                    <GradientStop x:Name="NeonStop2" Color="#002E78" Offset="0.3"/>
                    <GradientStop x:Name="NeonStop3" Color="#00A7FF" Offset="0.7"/>
                    <GradientStop x:Name="NeonStop4" Color="#4F1DFF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="ARSADECK"
                                   Foreground="#EAF6FF"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="–"
                                    Width="34"
                                    Height="26"
                                    Margin="0,0,6,0"
                                    Click="MinimizeButton_Click"
                                    Style="{StaticResource TopButtonStyle}"/>

                            <Button Content="X"
                                    Width="34"
                                    Height="26"
                                    Click="CloseButton_Click"
                                    Style="{StaticResource TopButtonStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            CornerRadius="10"
                            Background="#16000000"
                            BorderBrush="#2E5C7A"
                            BorderThickness="1"
                            Padding="10,8"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="COM-порт:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>

                            <ComboBox x:Name="PortComboBox"
                                      Grid.Column="1"
                                      Width="42"
                                      Height="28"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      SelectionChanged="PortComboBox_SelectionChanged"
                                      Style="{StaticResource TopComboBoxStyle}"/>

                            <Border Grid.Column="2"
                                    Background="#1E3A32"
                                    BorderBrush="#33D17A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8,4"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="PortStatusText"
                                           Foreground="#C8FFE8"
                                           Text="Порт не выбран"
                                           MinWidth="105"/>
                            </Border>

                            <Button Grid.Column="3"
                                    Content="Обновить"
                                    Click="RefreshPortsButton_Click"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource TopButtonStyle}"/>

                            <Button Grid.Column="4"
                                    Content="Сохранить"
                                    Click="SaveConfigButton_Click"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource TopButtonStyle}"/>

                            <Button Grid.Column="5"
                                    Content="Отправить"
                                    Click="SendConfigButton_Click"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource TopButtonStyle}"/>

                            <Button Grid.Column="6"
                                    Content="Очистить"
                                    Click="ClearDataButton_Click"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource TopButtonStyle}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            CornerRadius="10"
                            Background="#12000000"
                            BorderBrush="#2E5C7A"
                            BorderThickness="1"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Конфиг:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>

                            <ComboBox x:Name="ConfigComboBox"
                                      Grid.Column="1"
                                      Width="190"
                                      Height="28"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      SelectionChanged="ConfigComboBox_SelectionChanged"
                                      Style="{StaticResource TopComboBoxStyle}"/>

                            <Button Grid.Column="2"
                                    Content="Сохранить как"
                                    Click="SaveConfigAsButton_Click"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource TopButtonStyle}"/>

                            <Button Grid.Column="3"
                                    Content="Удалить"
                                    Click="DeleteConfigButton_Click"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource TopButtonStyle}"/>

                            <TextBlock Grid.Column="4"
                                       Text="Управление профилями"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="#A9C7DA"
                                       FontSize="12"
                                       Opacity="0.9"/>
                        </Grid>
                    </Border>
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding KeysBoxes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="3" Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="9"
                                    Style="{StaticResource TileBorderStyle}">

                                <Border.ContextMenu>
                                    <ContextMenu Style="{StaticResource ModernContextMenuStyle}"
                                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Выбрать EXE (режим запуска)"
                                                  Style="{StaticResource ModernMenuItemStyle}"
                                                  Click="PickExeMenuItem_Click"/>

                                        <MenuItem Header="Выбрать картинку (режим кастом)"
                                                  Style="{StaticResource ModernMenuItemStyle}"
                                                  Click="PickImageMenuItem_Click"/>

                                        <Separator Style="{StaticResource ModernSeparatorStyle}"/>

                                        <MenuItem Header="Переименовать (кастом)"
                                                  Style="{StaticResource ModernMenuItemStyle}"
                                                  Click="RenameCustomMenuItem_Click"/>

                                        <MenuItem Header="Сбросить кастом"
                                                  Style="{StaticResource ModernMenuItemStyle}"
                                                  Click="ResetCustomMenuItem_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid Margin="4">
                                    <Border CornerRadius="14"
                                            BorderBrush="#31435C"
                                            BorderThickness="1.2">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#18202B" Offset="0.0"/>
                                                <GradientStop Color="#121923" Offset="0.55"/>
                                                <GradientStop Color="#0D1219" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <Grid Margin="0" ClipToBounds="True">

                                            <Border CornerRadius="14" Opacity="0.16" IsHitTestVisible="False">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#120032" Offset="0.0"/>
                                                        <GradientStop Color="#143A7A" Offset="0.3"/>
                                                        <GradientStop Color="#146F7A" Offset="0.7"/>
                                                        <GradientStop Color="#3C1A8F" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <Border CornerRadius="14"
                                                    Margin="1"
                                                    BorderThickness="1"
                                                    BorderBrush="#18FFFFFF"
                                                    Background="#08FFFFFF"
                                                    IsHitTestVisible="False"/>

                                            <Grid Margin="10">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid.Resources>
                                                    <Style x:Key="AppIconStyle" TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static local:KeyBoxType.App}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>

                                                    <Style x:Key="CustomImageStyle" TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static local:KeyBoxType.Custom}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Resources>

                                                <Border Grid.Row="0"
                                                        Margin="4,2,4,8"
                                                        CornerRadius="12"
                                                        BorderBrush="#223247"
                                                        BorderThickness="1"
                                                        Background="#101722"
                                                        Padding="8">
                                                    <Grid>
                                                        <Border CornerRadius="10"
                                                                Opacity="0.16"
                                                                IsHitTestVisible="False">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#00B5FF" Offset="0.0"/>
                                                                    <GradientStop Color="#00FFE0" Offset="0.5"/>
                                                                    <GradientStop Color="#7A2CFF" Offset="1.0"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>

                                                        <Border CornerRadius="10"
                                                                Background="#16FFFFFF"
                                                                VerticalAlignment="Top"
                                                                Height="24"
                                                                IsHitTestVisible="False"/>

                                                        <Image x:Name="AppIcon"
                                                               Source="{Binding Icon}"
                                                               Width="52"
                                                               Height="52"
                                                               Style="{StaticResource AppIconStyle}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                                        <Image x:Name="CustomImageControl"
                                                               Source="{Binding CustomImage}"
                                                               Width="86"
                                                               Height="86"
                                                               Style="{StaticResource CustomImageStyle}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Row="1"
                                                        Margin="4,0,4,6"
                                                        CornerRadius="8"
                                                        Padding="8,5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#0A6D73" Offset="0.0"/>
                                                            <GradientStop Color="#15979B" Offset="0.5"/>
                                                            <GradientStop Color="#0A6D73" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#00F0FF"
                                                                          BlurRadius="10"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.18"/>
                                                    </Border.Effect>

                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Title}"
                                                           Foreground="#F4F8FF"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,6"
                                                           FontSize="15"
                                                           FontWeight="Bold">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="#00E5FF"
                                                                          BlurRadius="6"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.18"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>

                                                <ToggleButton Grid.Row="3"
                                                              Style="{StaticResource IosToggleStyle}"
                                                              IsChecked="{Binding Mode,
                                                                                  Converter={StaticResource LedModeToBoolConverter},
                                                                                  Mode=TwoWay}"
                                                              HorizontalAlignment="Center"
                                                              Margin="0,2,0,0"/>

                                                <Grid Grid.Row="4" Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="Toggle"
                                                               Foreground="#B9C4D3"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,0,7,0"
                                                               FontSize="10"/>

                                                    <TextBlock Grid.Column="1"
                                                               Text="Hold"
                                                               Foreground="#B9C4D3"
                                                               HorizontalAlignment="Left"
                                                               Margin="7,0,0,0"
                                                               FontSize="10"/>
                                                </Grid>
                                            </Grid>

                                            <Border CornerRadius="14"
                                                    IsHitTestVisible="False"
                                                    Opacity="0.06">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#00FFFFFF" Offset="0.0"/>
                                                        <GradientStop Color="#55FFFFFF" Offset="0.45"/>
                                                        <GradientStop Color="#00FFFFFF" Offset="0.9"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.RenderTransform>
                                                    <TranslateTransform X="-120"/>
                                                </Border.RenderTransform>
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                                 From="-220"
                                                                                 To="220"
                                                                                 Duration="0:0:2.5"
                                                                                 RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                            </Border>

                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Row="2"
                           Text="ПКМ по квадрату — выбрать программу. Переключатель — режим TOGGLE/HOLD. F13–F24 — запуск."
                           HorizontalAlignment="Center"
                           Margin="0,10,0,2"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#F4F8FF"
                           FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Window>